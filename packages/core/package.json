{
  "name": "@ts-sqlx/core",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./config.js": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    },
    "./adapters/database/*": {
      "types": "./dist/adapters/database/*",
      "default": "./dist/adapters/database/*"
    },
    "./adapters/typescript/*": {
      "types": "./dist/adapters/typescript/*",
      "default": "./dist/adapters/typescript/*"
    },
    "./queryDetector.js": {
      "types": "./dist/queryDetector.d.ts",
      "default": "./dist/queryDetector.js"
    },
    "./diagnostics.js": {
      "types": "./dist/diagnostics.d.ts",
      "default": "./dist/diagnostics.js"
    },
    "./types.js": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./cache.js": {
      "types": "./dist/cache.d.ts",
      "default": "./dist/cache.js"
    },
    "./perf.js": {
      "types": "./dist/perf.d.ts",
      "default": "./dist/perf.js"
    }
  },
  "scripts": {
    "build": "tsc"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.2.0",
    "libpg-query": "^15.2.0",
    "pg": "^8.13.0",
    "smol-toml": "^1.6.1",
    "ts-morph": "^25.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@types/pg": "^8.11.0",
    "typescript": "^5.7.0"
  }
}
