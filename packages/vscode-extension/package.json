{
  "name": "ts-sqlx",
  "displayName": "ts-sqlx",
  "description": "Compile-time SQL checking for TypeScript",
  "version": "0.2.1",
  "publisher": "ts-sqlx",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:typescript"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "ts-sqlx",
      "properties": {
        "ts-sqlx.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable ts-sqlx diagnostics"
        }
      }
    }
  },
  "scripts": {
    "build": "node build.mjs",
    "package": "pnpm build && vsce package --no-dependencies"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@bluedrop-learning-networks/ts-sqlx-language-server": "workspace:*",
    "@types/vscode": "^1.85.0",
    "@vercel/ncc": "^0.38.4",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.25.0"
  }
}
